# 이 파일을 복사해서 .env 로 만들고 실제 값을 채우세요.
# 실제 .env 는 .gitignore 로 git에 안 올라갑니다 (비밀키 보호).

SUPABASE_URL=https://hffuxqijuoempxeblddx.supabase.co

# ↓ Supabase → Settings → API 의 service_role (secret) 키. 절대 공개 금지.
#   (이 프로젝트의 GitHub → Settings → Secrets 에도 SUPABASE_SERVICE_KEY 로 등록돼 있음)
SUPABASE_SERVICE_KEY=여기에_service_role_키_붙여넣기
